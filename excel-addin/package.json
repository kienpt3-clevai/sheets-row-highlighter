{
  "name": "excel-row-highlighter-addin",
  "version": "1.0.0",
  "description": "Excel Row/Column Highlighter - Office Add-in",
  "main": "src/taskpane/taskpane.js",
  "scripts": {
    "start": "office-addin-debugging start manifest.xml",
    "start:desktop": "office-addin-debugging start manifest.xml desktop",
    "stop": "office-addin-debugging stop manifest.xml",
    "build": "webpack --mode production",
    "dev-server": "webpack serve --mode development",
    "sideload": "office-addin-dev-certs install && office-addin-debugging start manifest.xml"
  },
  "dependencies": {
    "core-js": "^3.36.0",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^12.0.2",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^5.1.0",
    "office-addin-dev-certs": "^1.13.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.0.0"
  }
}
